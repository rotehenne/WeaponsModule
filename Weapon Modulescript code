function WeaponsModule:RemoveToolOnBack()
		local character = self.Tool.Parent 
		local torso = character.Torso
		local BackToolPart = torso.BackToolPart

		-- Loops through the children of the character's Torso and destroys the ToolBackModel and the Weld
		for i, Child in pairs(BackToolPart:GetChildren()) do
			if Child:IsA("Model") and Child.Name == self.Tool.name .."ToolBackModel" then
				Child:Destroy()
			end

			if Child:IsA("Weld") and Child.Name == self.Tool.name .."ToolBackWeld" then
				Child:Destroy()
			end
		end
end
function WeaponsModule:RemoveToolOnHip()
	local character = self.Tool.Parent 
	local rightLeg = character["Right Leg"]
	local HipToolPart = rightLeg.HipToolPart

	-- Loops through the children of the character's Torso and destroys the ToolBackModel and the Weld
	for i, Child in pairs(HipToolPart:GetChildren()) do
		if Child:IsA("Model") and Child.Name == self.Tool.name .."ToolHipModel" then
			Child:Destroy()
		end

		if Child:IsA("Weld") and Child.Name == self.Tool.name .."ToolHipWeld" then
			Child:Destroy()
		end
	end


end
function WeaponsModule:playIdleAnim()
	local character = self.Tool.Parent
	local animator = character:WaitForChild("Humanoid"):WaitForChild("Animator")
	local idleAnim = self.Tool.IdleAnim_Folder.IdleAnim
	self.idleAnimTrack= animator:LoadAnimation(idleAnim)
	self.idleAnimTrack:Play()	
end
function WeaponsModule:stopIdleAnim()
	if self.idleAnimTrack then
		self.idleAnimTrack:Stop()
	end
end

function WeaponsModule:Activated()
	if self.ActivationDebounce == false then
		if self.Tool.Parent:FindFirstChild("BlockingBoolean") then
			local blockingBoolean = self.Tool.Parent:FindFirstChild("BlockingBoolean")
			local player = playersService:GetPlayerFromCharacter(self.Tool.Parent)
			local playerIsStunned = playerInfoModule.CheckIfPlayerIsStunned(player)
			if blockingBoolean.Value == false and playerIsStunned ~= true then
				if self.InShiftLock == false then
					combatLockToggle:FireClient(player,true)
					self.InShiftLock = true
				end
				self.ActivationDebounce = true
				if #self.AnimationTable > 0 then
					local randomAnimationNumber = math.random(1, #self.AnimationTable)
					if self.Tool:GetAttribute("ToolActivateSoundId") ~= "" then -- play toolActivate sound if it has one
						if not self.Tool.Handle:FindFirstChild("ToolActivateSound") then
							local sound = Instance.new("Sound", self.Tool.Handle)
							sound.Name = "ToolActivateSound"
							sound.SoundId = self.Tool:GetAttribute("ToolActivateSoundId")
							sound.Volume = self.Tool:GetAttribute("ToolActivateSoundVolume") 
							sound.RollOffMaxDistance = 100
						end
						local toolActivateSound = self.Tool.Handle:FindFirstChild("ToolActivateSound")
						toolActivateSound:Play()
					end
					local randomAnim = self.AnimationTable[randomAnimationNumber]
					self.currentToolAnimationTrack = self.Tool.Parent:WaitForChild("Humanoid").Animator:LoadAnimation(randomAnim)
					self.currentToolAnimationTrack:Play()
				end
				if 	self.Tool:GetAttribute("ToolDamage") > 0 then
					self:ActivateCaster()
				end
				self.ActivationDebounce = false
			end
		end
	end
	
end



function WeaponsModule:Equip()
	if playersService:GetPlayerFromCharacter(self.Tool.Parent) then

			local character = self.Tool.Parent
			self.lastPlayerHolding = playersService:GetPlayerFromCharacter(self.Tool.Parent)
			local rayCastParams = RaycastParams.new()
			rayCastParams.FilterType = Enum.RaycastFilterType.Exclude
			rayCastParams.FilterDescendantsInstances = {character}
			local hitbox = clientCast.new(self.Tool.Hitbox_Part,rayCastParams)
			hitbox:SetOwner(playersService:GetPlayerFromCharacter(self.Tool.Parent) )
			self.Caster = hitbox
			hitbox.Collided:Connect(function(params)
				if params.Instance.Parent:FindFirstChild("Humanoid") then
					if not table.find(self.HitModels,params.Instance.Parent) then
						table.insert(self.HitModels,params.Instance.Parent)
						local model = params.Instance.Parent
						self:OnHit(model)
						--params.Instance.Parent.HumanoidRootPart:ApplyImpulse(params.Instance.Parent.HumanoidRootPart.Position.Unit * 100)
					end
				end	
			end)
				self:playIdleAnim()
				if self.Tool:GetAttribute("ToolCarriedOnBack") == true then 
					self:RemoveToolOnBack()
				end
				if self.Tool:GetAttribute("ToolCarriedOnHip") == true then
					self:RemoveToolOnHip()
				end
				local playerCharacter = self.Tool.Parent
				if playerCharacter:IsA("Model") then
					if #playerCharacter.NonBodyPartItems:GetChildren() > 0 then
						local player = playersService:GetPlayerFromCharacter(playerCharacter)
						self.Tool.Parent = player.Backpack
					end
					for i, part in ipairs (self.Tool:GetChildren()) do
						if part:IsA("Part") or part:IsA("UnionOperation") or part:IsA("MeshPart")then
							part.CanCollide = false
							part.CanTouch = true
							local grip = playerCharacter["Right Arm"]:WaitForChild("RightGrip")
							grip.C0 = CFrame.new(0,0,0)
							grip.Part0 = playerCharacter["Right Arm"].HandCenter
							grip.Part1 = self.Tool.Handle
							grip.Name = "RightGrip"
							grip.Parent = playerCharacter["Right Arm"]
						end
					end
				end
	end
end	
	


function WeaponsModule:Unequip()
		if self.Caster then
			self.Caster:Stop()
			self.Caster = nil
		end
		if self.InShiftLock == true then
			combatLockToggle:FireClient(self.lastPlayerHolding,false)
			self.InShiftLock = false
		end
		self:stopIdleAnim()
		for i, part in ipairs (self.Tool:GetChildren()) do
			if part:IsA("Part") or part:IsA("UnionOperation") or part:IsA("MeshPart") then
				part.CanTouch = false
				part.Massless = true
			end
		end
		if self.Tool:GetAttribute("ToolCarriedOnBack") == true then 
			self:placeToolOnBack()
		end
		if self.Tool:GetAttribute("ToolCarriedOnHip") == true then
			self:placeToolOnHip()
		end
end
function WeaponsModule:setToolPartsCanCollideToTrue()
	for i, part in ipairs(self.Tool:GetChildren()) do
		if part:IsA("Part") or part:IsA("UnionOperation") or part:IsA("MeshPart") then
			part.CanCollide = true
			part.Massless = false
		end
	end
end
function WeaponsModule:toolParentChanged()
	if self.Tool.Parent == game.Workspace then
		self.Tool.Parent = ToolsInWorkspaceFolder
		self:setToolPartsCanCollideToTrue(self.Tool)
	end
	if self.Tool.Parent == ToolsInWorkspaceFolder then
		self.PickUpPrompt.Enabled = true
	else
		self.PickUpPrompt.Enabled = false
	end
end


return WeaponsModule
