local WeaponsModule = {}

WeaponsModule.__index = WeaponsModule

function WeaponsModule.new(WeaponTool)
	local self = setmetatable({},WeaponsModule)
	self.Tool = WeaponTool
	self.Handle = self.Tool.Handle
	self.PickUpPrompt = self.Handle.PickUpTool
	self.Caster = nil
	self.InShiftLock = false
	self.lastPlayerHolding = nil
	self.showHitBoxForTesting = false
	self.ToolPlaysSounds = true
	self.currentToolAnimationTrack = nil
	self.idleAnimTrack = nil
	self.AnimationTable = {}
	self.ActivationDebounce = false
	self.ToolHitdebounce = false
	self.HurtOutline = nil
	self.HitModels = {}
	return self
end

function WeaponsModule:SetUpTool()
	self.Handle.Transparency = 1
	self.PickUpPrompt.RequiresLineOfSight = false
	self.PickUpPrompt.ObjectText = self.Tool.Name
	self.Handle.CanTouch = false
	--Set up Animtions
	for i, item in ipairs(self.Tool:GetChildren()) do
		if item:IsA("Animation") then
			local animation = item
			if animation.AnimationId ~= "" then
				table.insert(self.AnimationTable, animation)
			end
		end
	end
--GetHurtOutline
	if replicatedStorage:FindFirstChild("HurtHighlight") then
		--Get one already made
		self.HurtOutline = replicatedStorage:FindFirstChild("HurtHighlight")
	else
		--define new highlight
		self.HurtOutline = Instance.new("Highlight", replicatedStorage)
		self.HurtOutline.Name = "HurtHighlight"
		self.HurtOutline.FillColor = Color3.new(255,0,0)
		self.HurtOutline.FillTransparency = 0.8
		self.HurtOutline.Parent = game:GetService("ReplicatedStorage")
		self.HurtOutline.OutlineTransparency = 1
	end
end


function WeaponsModule:OnHit(hitmodel)
	local model = hitmodel
	if model.Parent ~= nil then
		if model:IsA("Model") and self.Tool:GetAttribute("DamageType") == "Creature"  then
			if self.ToolHitdebounce == false and self.ActivationDebounce == true  and ageReqsModule.CheckIfCanAttack(self.Tool.Parent) then
				self.ToolHitdebounce = true
				if model:FindFirstChild("Humanoid")  then
					local Humanoid = model:FindFirstChild("Humanoid")
					local hurtOutlineClone = self.HurtOutline:Clone()
					if playersService:GetPlayerFromCharacter(Humanoid.Parent) then
						local player = playersService:GetPlayerFromCharacter(Humanoid.Parent)
						local playerCharacter = player.Character
						if playerCharacter:FindFirstChild("BlockingBoolean") then
							if playerCharacter:FindFirstChild("BlockingBoolean").Value == true then
								hurtOutlineClone = nil
							end
						end
					end
					local character = model
					if playersService:GetPlayerFromCharacter(Humanoid.Parent) then--check if its a player
						local attackingPlayer = playersService:GetPlayerFromCharacter(self.Tool.Parent)
						local player = playersService:GetPlayerFromCharacter(Humanoid.Parent)
						if playerDamageModule.CanHurtPlayer(attackingPlayer,player) then -- checks if on teams or not and if teamkill is on
							playerDamageModule.CombatDamagePlayer(player, self.Tool:GetAttribute("ToolDamage"), attackingPlayer)
						else    -- this is if they are sameteam and don't have teamkill on
							hurtOutlineClone = nil
							playerDamageModule.CombatDamagePlayer(player, self.Tool:GetAttribute("ToolDamage"), attackingPlayer)
						end
					else
						Humanoid.Health -= self.Tool:GetAttribute("ToolDamage")
					end
					if hurtOutlineClone then
						hurtOutlineClone.Parent = character
					end
					if self.Tool:GetAttribute("AttackHitSoundId") ~= "" then
						if not self.Tool.Handle:FindFirstChild("AttackHitSound") then -- attack hit sound
							local sound = Instance.new("Sound", self.Tool.Handle)
							sound.Name = "AttackHitSound"
							sound.SoundId = self.Tool:GetAttribute("AttackHitSoundId")
						
							sound.Volume = self.Tool:GetAttribute("AttackHitSoundVolume")
							sound.RollOffMaxDistance = 100
						end
						if hurtOutlineClone then -- uhhh quicker way to say whether or not the opponent is blocking because we set hurt outline to nil when they are blocking so you won't here slicing when the opponents blocking it just wouldn't make sense
							local AttackHitSound = self.Tool.Handle:FindFirstChild("AttackHitSound")
							AttackHitSound:Play()
						end
					end
					if hurtOutlineClone then
						task.delay(.1,function()
							hurtOutlineClone:Destroy()
						end)
					end
					self.ToolHitdebounce = false
				end
			end
		end
	end
end

function WeaponsModule:ActivateCaster()
	local playerCharacter = self.Tool.Parent
	local player = playersService:GetPlayerFromCharacter(playerCharacter)
	if self.Caster then
		self.Caster:Start()
		self.currentToolAnimationTrack.Ended:Wait()
		if self.Caster then
			self.Caster:Stop()
		end
		self.HitModels = {} -- Resets Hit Models after finished with swing
	end
end



function WeaponsModule:PlaceOnHip()
	if self.Tool.Parent.Name == "Backpack" then 
		local backpack = self.Tool.Parent
		local player = backpack.Parent
		local character = player.Character
		local rightLeg = character["Right Leg"]
		local hipToolPart = rightLeg.HipToolPart
		local toolClone = self.Tool:Clone()
		local toolHipModel = Instance.new("Model")
		toolHipModel.Parent = hipToolPart
		toolHipModel.Name = self.Tool.Name .."ToolHipModel"-- classify by name so we only destroy Hipmodels of the same item type
		--LOOP THROUGH WHATS IN TOOLCLONE AND PUTS IT INTO Hip MODEL
		for i, child in ipairs(toolClone:GetChildren()) do
			if child:IsA("Part")  or child:IsA("UnionOperation") or child:IsA("MeshPart") then
				child.Parent = toolHipModel
				child.CanCollide = false
				child.Massless = true
			end
		end
		-- set Primary Part OF Model To Tools Handle
		toolHipModel.PrimaryPart = toolHipModel:FindFirstChild("Handle")
		--Creates the Weld
		local ToolHipWeld = Instance.new("Weld")
		ToolHipWeld.Name = self.Tool.Name .."ToolHipWeld"-- classify by name so we only destroy Hipmodels of the same item type
		ToolHipWeld.Parent = rightLeg.HipToolPart
		-- set part 0 and part 1
		ToolHipWeld.Part0 = rightLeg.HipToolPart
		ToolHipWeld.Part1 = toolHipModel:FindFirstChild("Handle")
		--Set CFRAME TO Hip tool part
		wait(.5)
	end
end
